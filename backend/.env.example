# MongoDB connection string. Inside Kubernetes this points at the mongo Service.
MONGO_URI=mongodb://mongo:27017/skfurniture
# Long random string used to sign JWTs - change this in production
JWT_SECRET=change-this-to-a-long-random-secret
# Port the API listens on
PORT=5000
# Comma separated list of origins allowed to call this API ("*" allows all)
CORS_ORIGIN=*

# Optional: external MySQL server for a dual-write copy of orders.
# host.docker.internal resolves to the machine running Docker Desktop/kind,
# which is what you want when MySQL runs on the same laptop (Windows or WSL).
# Leave these unset to run MongoDB-only (MySQL sync is skipped automatically).
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=skfurniture
MYSQL_PASSWORD=change-this-password
MYSQL_DATABASE=sk_furniture
